class Ah < Formula
  desc "Agent History - cross-agent session search CLI"
  homepage "https://github.com/nihen/ah"
  version "${VERSION}"
  license "MIT"

  on_macos do
    on_arm do
      url "${BASE_URL}/ah-darwin-arm64"
      sha256 "${SHA_DARWIN}"
    end
  end

  on_linux do
    on_intel do
      url "${BASE_URL}/ah-linux-x86_64"
      sha256 "${SHA_LINUX}"
    end
  end

  def install
    bin.install Dir["ah-*"].first => "ah"
  end

  test do
    assert_match "ah", shell_output("#{bin}/ah --version")
  end
end
